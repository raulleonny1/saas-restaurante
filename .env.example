# Firebase (required for Auth / Firestore)
# Copy to .env.local — never commit real keys.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=saas-bar-restaurante.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=saas-bar-restaurante
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=saas-bar-restaurante.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# SumUp
NEXT_PUBLIC_SUMUP_APP_ID=
SUMUP_API_KEY=

# Resend
RESEND_API_KEY=

# OpenAI (opcional — pule respuestas del Gerente IA en /api/ai/chat)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
