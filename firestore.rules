rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function memberDoc(restaurantId) {
      return get(/databases/$(database)/documents/restaurants/$(restaurantId)/members/$(request.auth.uid));
    }

    function isMember(restaurantId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/restaurants/$(restaurantId)/members/$(request.auth.uid)) &&
        memberDoc(restaurantId).data.active == true;
    }

    function memberRole(restaurantId) {
      let d = memberDoc(restaurantId).data;
      return d.keys().hasAny(['roleId']) ? d.roleId : d.role;
    }

    function canManage(restaurantId) {
      return isMember(restaurantId) &&
        memberRole(restaurantId) in ['propietario', 'gerente', 'super_admin'];
    }

    /** First-time owner bootstrap or invite accept. */
    function isSelfMemberCreate(restaurantId, uid) {
      return isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.restaurantId == restaurantId
        && request.resource.data.active == true;
    }

    function canWriteAudit(restaurantId) {
      return canManage(restaurantId);
    }

    function canAccessBranch(restaurantId, branchId) {
      return isMember(restaurantId) && (
        !(memberDoc(restaurantId).data.keys().hasAny(['branchIds'])) ||
        memberDoc(restaurantId).data.branchIds.size() == 0 ||
        branchId in memberDoc(restaurantId).data.branchIds
      );
    }

    function authEmail() {
      return request.auth.token.email;
    }

    // Public slug index — members of that restaurant (bootstrap + managers)
    match /restaurantSlugs/{slug} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasAll(['slug', 'restaurantId'])
        && isMember(request.resource.data.restaurantId);
      allow delete: if isSignedIn()
        && resource.data.keys().hasAny(['restaurantId'])
        && canManage(resource.data.restaurantId);
    }

    match /customDomains/{host} {
      allow read: if true;
      allow create, update: if isSignedIn()
        && request.resource.data.keys().hasAny(['restaurantId'])
        && canManage(request.resource.data.restaurantId);
      allow delete: if isSignedIn()
        && resource.data.keys().hasAny(['restaurantId'])
        && canManage(resource.data.restaurantId);
    }

    // Cross-tenant invites (email lookup); data still references one restaurantId
    match /memberInvites/{inviteId} {
      allow read: if isSignedIn() && (
        resource.data.email == authEmail()
        || canManage(resource.data.restaurantId)
      );
      allow create: if canManage(request.resource.data.restaurantId)
        && request.resource.data.status == 'pending'
        && request.resource.data.restaurantId is string
        && request.resource.data.email is string;
      allow update: if canManage(resource.data.restaurantId)
        || (
          isSignedIn()
          && resource.data.email == authEmail()
          && request.resource.data.status in ['accepted', 'revoked']
        );
      allow delete: if canManage(resource.data.restaurantId);
    }

    match /users/{uid} {
      allow read: if isSelf(uid);
      allow create: if isSelf(uid);
      allow update: if isSelf(uid);
      allow delete: if false;
    }

    match /restaurants/{restaurantId} {
      // Isolated: members OR public website. No cross-tenant listing of private tenants.
      allow read: if isMember(restaurantId)
        || resource.data.websitePublished == true;
      allow create: if isSignedIn()
        && request.resource.data.id == restaurantId;
      allow update, delete: if canManage(restaurantId);

      match /members/{uid} {
        allow read: if isMember(restaurantId) || isSelf(uid);
        allow create: if canManage(restaurantId) || isSelfMemberCreate(restaurantId, uid);
        // Managers, or self-heal when users/{uid}.role is staff but member was raced as cliente
        allow update: if canManage(restaurantId) || (
          isSelf(uid)
          && resource.data.uid == request.auth.uid
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
            in ['propietario', 'gerente', 'supervisor', 'cajero', 'mesero', 'cocinero', 'barista', 'repartidor', 'super_admin']
          && request.resource.data.roleId
            == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
          && request.resource.data.role
            == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.restaurantId == restaurantId
        );
        allow delete: if canManage(restaurantId);
      }

      match /branches/{branchId} {
        allow read: if isMember(restaurantId) ||
          get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.websitePublished == true;
        allow create: if canManage(restaurantId)
          && request.resource.data.restaurantId == restaurantId;
        allow update, delete: if canManage(restaurantId);
      }

      match /billing/{docId} {
        allow read: if canManage(restaurantId);
        allow create, update: if canManage(restaurantId)
          && request.resource.data.restaurantId == restaurantId;
        allow delete: if false;
      }

      match /invoices/{invoiceId} {
        allow read: if canManage(restaurantId);
        allow create, update: if canManage(restaurantId)
          && request.resource.data.restaurantId == restaurantId;
        allow delete: if false;
      }

      match /websiteSettings/{docId} {
        allow read: if true;
        allow create: if isMember(restaurantId)
          && request.resource.data.restaurantId == restaurantId;
        allow update: if canManage(restaurantId)
          && request.resource.data.restaurantId == restaurantId;
        allow delete: if canManage(restaurantId);
      }

      match /blogPosts/{postId} {
        allow read: if isMember(restaurantId) || resource.data.status == 'published';
        allow write: if canManage(restaurantId);
      }

      match /siteEvents/{eventId} {
        allow read: if isMember(restaurantId) || resource.data.status == 'published';
        allow write: if canManage(restaurantId);
      }

      match /reviews/{reviewId} {
        allow read: if isMember(restaurantId) || resource.data.status == 'approved';
        allow create: if request.resource.data.restaurantId == restaurantId
          && request.resource.data.status == 'pending'
          && request.resource.data.source == 'web';
        allow update, delete: if canManage(restaurantId);
      }

      match /categories/{docId} {
        allow read: if isMember(restaurantId) || resource.data.status == 'active';
        allow write: if isMember(restaurantId);
      }

      match /products/{docId} {
        allow read: if isMember(restaurantId) || resource.data.status == 'active';
        allow write: if isMember(restaurantId);
      }

      match /promotions/{docId} {
        allow read: if isMember(restaurantId) || resource.data.status in ['active', 'scheduled'];
        allow write: if isMember(restaurantId);
      }

      match /customers/{customerId} {
        allow read: if isMember(restaurantId)
          || (isSignedIn() && resource.data.uid == request.auth.uid);
        allow create: if isMember(restaurantId) || (
          isSignedIn()
          && request.resource.data.restaurantId == restaurantId
          && request.resource.data.uid == request.auth.uid
        );
        allow update: if isMember(restaurantId)
          || (isSignedIn() && resource.data.uid == request.auth.uid);
        allow delete: if canManage(restaurantId);
      }

      match /loyaltyAccounts/{accountId} {
        allow read: if isMember(restaurantId) || (
          isSignedIn()
          && get(/databases/$(database)/documents/restaurants/$(restaurantId)/customers/$(accountId)).data.uid == request.auth.uid
        );
        allow create: if isMember(restaurantId) || (
          isSignedIn()
          && request.resource.data.restaurantId == restaurantId
          && request.resource.data.customerId == accountId
          && get(/databases/$(database)/documents/restaurants/$(restaurantId)/customers/$(accountId)).data.uid == request.auth.uid
        );
        allow update, delete: if isMember(restaurantId);
      }

      match /loyaltyTransactions/{txId} {
        allow read: if isMember(restaurantId) || (
          isSignedIn()
          && get(/databases/$(database)/documents/restaurants/$(restaurantId)/customers/$(resource.data.customerId)).data.uid == request.auth.uid
        );
        allow write: if isMember(restaurantId);
      }

      match /customerHistory/{entryId} {
        allow read: if isMember(restaurantId) || (
          isSignedIn()
          && get(/databases/$(database)/documents/restaurants/$(restaurantId)/customers/$(resource.data.customerId)).data.uid == request.auth.uid
        );
        allow write: if isMember(restaurantId);
      }

      match /personalizedPromos/{promoId} {
        allow read: if isMember(restaurantId) || (
          isSignedIn()
          && get(/databases/$(database)/documents/restaurants/$(restaurantId)/customers/$(resource.data.customerId)).data.uid == request.auth.uid
        );
        allow write: if isMember(restaurantId);
      }

      match /orders/{orderId} {
        allow read: if isMember(restaurantId)
          || (isSignedIn() && resource.data.customerUid == request.auth.uid);
        allow create: if isMember(restaurantId) || (
          request.resource.data.restaurantId == restaurantId
          && request.resource.data.channel == 'online'
          && request.resource.data.status == 'open'
          && (
            request.resource.data.createdBy == 'web_guest'
            || (
              isSignedIn()
              && request.resource.data.customerUid == request.auth.uid
              && request.resource.data.createdBy == request.auth.uid
            )
          )
        );
        allow update, delete: if isMember(restaurantId);
      }

      match /reservations/{reservationId} {
        allow read: if isMember(restaurantId)
          || (isSignedIn() && resource.data.customerUid == request.auth.uid);
        allow create: if isMember(restaurantId) || (
          request.resource.data.restaurantId == restaurantId
          && request.resource.data.status == 'pending'
          && (
            request.resource.data.source == 'web'
            || (
              isSignedIn()
              && request.resource.data.source == 'app'
              && request.resource.data.customerUid == request.auth.uid
            )
          )
        );
        allow update, delete: if isMember(restaurantId)
          || (
            isSignedIn()
            && resource.data.customerUid == request.auth.uid
            && request.resource.data.status in ['pending', 'cancelled']
          );
      }

      match /customerChats/{threadId} {
        allow read: if isMember(restaurantId)
          || (isSignedIn() && resource.data.customerUid == request.auth.uid);
        allow create: if isMember(restaurantId) || (
          isSignedIn()
          && request.resource.data.restaurantId == restaurantId
          && request.resource.data.customerUid == request.auth.uid
        );
        allow update: if isMember(restaurantId)
          || (isSignedIn() && resource.data.customerUid == request.auth.uid);

        match /messages/{messageId} {
          allow read: if isMember(restaurantId)
            || (
              isSignedIn()
              && get(/databases/$(database)/documents/restaurants/$(restaurantId)/customerChats/$(threadId)).data.customerUid == request.auth.uid
            );
          allow create: if isMember(restaurantId) || (
            isSignedIn()
            && request.resource.data.restaurantId == restaurantId
            && request.resource.data.senderUid == request.auth.uid
            && request.resource.data.senderRole == 'customer'
            && get(/databases/$(database)/documents/restaurants/$(restaurantId)/customerChats/$(threadId)).data.customerUid == request.auth.uid
          );
        }
      }

      match /appNotifications/{notificationId} {
        allow read: if isMember(restaurantId)
          || (isSignedIn() && resource.data.uid == request.auth.uid);
        allow create: if isMember(restaurantId)
          || (
            isSignedIn()
            && request.resource.data.restaurantId == restaurantId
            && request.resource.data.uid == request.auth.uid
          );
        allow update: if isMember(restaurantId)
          || (isSignedIn() && resource.data.uid == request.auth.uid);
        allow delete: if canManage(restaurantId);
      }

      match /auditLogs/{logId} {
        allow read: if canManage(restaurantId);
        allow create: if canWriteAudit(restaurantId)
          && request.resource.data.restaurantId == restaurantId;
        allow update, delete: if false;
      }

      match /aiSessions/{sessionId} {
        allow read, write: if isMember(restaurantId);

        match /messages/{messageId} {
          allow read, write: if isMember(restaurantId);
        }
      }

      // Default tenant collections — membership + branch ACL
      match /{collection}/{docId} {
        allow read: if isMember(restaurantId) && (
          !('branchId' in resource.data) ||
          resource.data.branchId == null ||
          canAccessBranch(restaurantId, resource.data.branchId)
        );
        allow create: if isMember(restaurantId)
          && request.resource.data.restaurantId == restaurantId
          && (
            !('branchId' in request.resource.data) ||
            request.resource.data.branchId == null ||
            canAccessBranch(restaurantId, request.resource.data.branchId)
          );
        allow update: if isMember(restaurantId)
          && resource.data.restaurantId == restaurantId
          && request.resource.data.restaurantId == restaurantId
          && (
            !('branchId' in resource.data) ||
            resource.data.branchId == null ||
            canAccessBranch(restaurantId, resource.data.branchId)
          );
        allow delete: if canManage(restaurantId);
      }
    }
  }
}
